import fs from 'fs';

async function run() {
  const url = "https://www.uniboard.com/en/colors";
  console.log("Fetching Uniboard colors page:", url);
  const html = await fetch(url).then(res => res.text());
  console.log("Fetched HTML length:", html.length);
  fs.writeFileSync('uniboard_test.html', html);
  
  if (html.length < 50000) {
      console.log("HTML:", html.slice(0, 1000));
  }
}
run();
